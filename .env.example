# Common Ground bot credentials. Never commit the real token.
CG_URL=https://chat.example.org
CG_BOT_TOKEN=cgb_replace_me
CG_COMMUNITY_ID=00000000-0000-4000-8000-000000000001
CG_CHANNEL_ID=00000000-0000-4000-8000-000000000002

# "hello" works without an OpenAI key. "openai" enables the Responses API.
BOT_MODE=hello
BOT_TRIGGER=!bot
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna
BOT_SYSTEM_PROMPT=You are a concise, helpful community assistant. Never claim to have taken an action you did not take.

HEALTH_PORT=3000
LOG_LEVEL=info
